{
	"info": {
		"_postman_id": "7f8b9e2d-4d5c-4a1b-9c8d-3f2a1b9c8d7e",
		"name": "Pullman - Refinamiento Beneficiarios",
		"description": "Colección para probar el flujo completo de convenios con beneficios/inscripción.",
